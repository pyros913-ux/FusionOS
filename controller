# models/controller.py
import torch.nn as nn
import torch

class PlasmaController(nn.Module):
    def __init__(self):
        super(PlasmaController, self).__init__()
        self.network = nn.Sequential(
            nn.Linear(2, 64),
            nn.ReLU(),
            nn.Linear(64, 32),
            nn.ReLU(),
            nn.Linear(32, 1),
            nn.Tanh()
        )
    
    def forward(self, x):
        return self.network(x)
